# Same defaults as ../poc/.env.example so the Node mocks (built straight from
# ../poc/apps/*) read the same environment values they always have.

# IAM Broker
AES256_SHARED_KEY=poc-aes256-key-must-be-32bytes!!
RC4_SHARED_KEY=poc-rc4-shared-key
ADMIN_API_KEY=poc-admin-api-key

# Shared between Dealers Portal and PID for the server-to-server launch-token
# call (PDF Step 2). In production this is provisioned per source-system by HQ.
DEALERS_API_KEY=poc-dealers-api-key

# /etc/hosts entries (add to your machine — same as the Node POC):
# 127.0.0.1 broker.sso.test portal.sso.test vendor.sso.test pid.sso.test dashboard.sso.test
# Access via: http://portal.sso.test:8000 (Traefik on port 8000)
