# Same defaults as ../poc/.env.example so the Node mocks (built straight from
# ../poc/apps/*) read the same environment values they always have.

# IAM Broker
AES256_SHARED_KEY=poc-aes256-key-must-be-32bytes!!
RC4_SHARED_KEY=poc-rc4-shared-key
ADMIN_API_KEY=poc-admin-api-key

# Shared between Dealers Portal and PID for the server-to-server launch-token
# call (PDF Step 2). In production this is provisioned per source-system by HQ.
DEALERS_API_KEY=poc-dealers-api-key

# /etc/hosts entries (add to your machine — same as the Node POC):
# 127.0.0.1 broker.sso.test portal.sso.test vendor.sso.test pid.sso.test dashboard.sso.test
# Access via: http://portal.sso.test:8000 (Traefik on port 8000)

# ── OIDC RP (broker authenticates users at upstream PID via OIDC) ─────────────
# Leave OIDC_PID_ENABLED=false until you have a client_id from the PID team.
# When false, /api/v1/auth/login returns 503 and nothing else is affected.
OIDC_PID_ENABLED=false
OIDC_PID_CLIENT_ID=
OIDC_PID_CLIENT_SECRET=
OIDC_PID_ISSUER=https://stg-partner.hmg-corp.io/auth
OIDC_PID_AUTHORIZE_ENDPOINT=https://stg-partner.hmg-corp.io/auth/authorize
OIDC_PID_TOKEN_ENDPOINT=https://stg-partner.hmg-corp.io/auth/token
OIDC_PID_JWKS_URI=https://stg-partner.hmg-corp.io/auth/cert
OIDC_PID_REDIRECT_URI=http://broker.sso.test:8000/api/v1/auth/callback
OIDC_PID_SCOPES=openid profile email

# ── SAML SP (broker receives SAML assertions from upstream IdP) ───────────────
# The SP keystore is generated locally via keytool — see docs in chat history.
# POC default passwords; rotate before any non-local use.
SAML_SP_ENTITY_ID=http://broker.sso.test:8000/sso/saml/metadata
# Paths are inside the broker container. Host path apps/iam-broker/keystore/
# is mounted at /keystore via docker-compose.yml.
SAML_SP_KEYSTORE=/keystore/broker-sp.p12
SAML_SP_KEYSTORE_PASSWORD=changeit
SAML_SP_KEY_ALIAS=broker-sp
SAML_SP_ACS_URL=http://broker.sso.test:8000/sso/saml/acs/pid

# IdP-role keystore — used by SamlTokenGenerator when signing outbound vendor
# assertions. Optional; if absent, an ephemeral keypair is generated at boot
# (existing behavior).
SAML_IDP_KEYSTORE=/keystore/broker-idp.p12
SAML_IDP_KEYSTORE_PASSWORD=changeit
SAML_IDP_KEY_ALIAS=broker-idp

# ── Upstream IdP (PID) ────────────────────────────────────────────────────────
SAML_IDP_ENTITY_ID=https://stg-partner.hmg-corp.io/auth
# Path inside the container where PID's IdP metadata is mounted (docker-compose
# volume — see Phase 2 changes). Drop the file from
# /Users/katiekim/Projects/IdP/metadata into this path.
SAML_IDP_METADATA_PATH=/idp-metadata/pid-metadata.xml

# ── Mock-PID launch-token HS256 (Phase 4) ─────────────────────────────────────
# Flip MOCK_PID_REQUIRE_SIGNATURE=true once mock-pid is updated to sign its
# launch token with HS256. Leaving it false keeps the existing unsigned flow.
MOCK_PID_REQUIRE_SIGNATURE=false
MOCK_PID_SHARED_SECRET=poc-mock-pid-shared-hs256-secret-min-32-bytes!
